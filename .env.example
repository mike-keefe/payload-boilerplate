# =============================================================================
# PAYLOAD CMS
# =============================================================================

# Database connection string
# Local dev default (matches docker-compose.yml): postgresql://payload:payload@localhost:5432/payload_dev
# Get from your hosting provider for production
DATABASE_URI=postgresql://payload:payload@localhost:5432/payload_dev

# Secret used to sign Payload session tokens — generate with: openssl rand -base64 32
# NEVER share or commit this value
PAYLOAD_SECRET=

# =============================================================================
# APPLICATION
# =============================================================================

# Full URL of the application (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# =============================================================================
# ERROR TRACKING (optional)
# =============================================================================

# Sentry DSN — leave empty to disable error tracking locally
# Get from: https://sentry.io → your project → Settings → Client Keys
SENTRY_DSN=

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================
# Add project-specific variables below this line during setup
# Document each one with a comment explaining what it is and where to get it
